{
  "manifest_version": 3,
  "name": "Telegram Web Code Watcher",
  "version": "1.0.0",
  "description": "Watch Telegram Web messages for Code: stakecom... and trigger local alerts.",
  "permissions": [
    "activeTab",
    "notifications",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "https://web.telegram.org/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.telegram.org/*"
      ],
      "js": [
        "shared/parser.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "128": "icons/icon-128.svg"
    },
    "default_title": "Telegram Code Watcher",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon-128.svg"
  }
}
